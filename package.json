{
  "name": "",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "run-p dev:*",
    "dev:server": "tsx ./server/index.ts",
    "start:server": "node ./dist/server-index.js",
    "build": "run-p build:*",
    "build:rr": "react-router build",
    "build:esbuild": "tsx ./esbuild.config.ts",
    "clean": "run-p clean:*",
    "clean:rr": "rm -rf ./build",
    "clean:dist": "rm -rf ./dist",
    "typecheck": "react-router typegen && tsc",
    "typesync:run": "typesync",
    "typesync:ci": "typesync --dry=fail",
    "lint:fix": "biome check --write .",
    "lint:ci": "biome ci .",
    "test": "NODE_ENV=test DB_URL=:memory: vitest run",
    "db:up": "tsx tasks/db.ts up && tsx tasks/dump-schema.ts",
    "db:down": "tsx tasks/db.ts down && tsx tasks/dump-schema.ts",
    "db:create": "tsx tasks/db.ts create",
    "db:latest": "tsx tasks/db.ts latest && tsx tasks/dump-schema.ts"
  },
  "dependencies": {
    "@libsql/kysely-libsql": "^0.4.1",
    "@react-router/express": "^7.14.1",
    "@react-router/node": "^7.14.1",
    "@react-router/serve": "^7.14.1",
    "classnames": "^2.5.1",
    "close-with-grace": "^2.5.0",
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "isbot": "^5.1.39",
    "kysely": "^0.28.16",
    "kysely-migration-cli": "^0.4.2",
    "morgan": "^1.10.1",
    "qs": "^6.15.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.14.1",
    "remix-utils": "^9.3.1",
    "ulidx": "^2.4.1",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@picocss/pico": "^2.1.1",
    "@react-router/dev": "^7.14.1",
    "@react-router/remix-routes-option-adapter": "^7.14.1",
    "@types/compression": "~1.8.1",
    "@types/express": "~5.0.6",
    "@types/morgan": "~1.9.10",
    "@types/qs": "~6.15.0",
    "@types/react": "~19.2.14",
    "@types/react-dom": "~19.2.3",
    "esbuild": "^0.28.0",
    "npm-run-all": "^4.1.5",
    "remix-flat-routes": "^0.8.5",
    "sscg": "^1.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typesync": "^0.14.3",
    "vite": "^8.0.8",
    "vite-plugin-environment": "^1.1.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4"
